# ═══════════════════════════════════════════════════════════════
#  Nexus Netplay Hub — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build Output ────────────────────────────────────────────────
dist/
dist-electron/
out/
build/
release/
*.AppImage
*.deb
*.rpm
*.dmg
*.exe
*.msi
*.pkg

# ── Obfuscated Source ────────────────────────────────────────────
src/main-obfuscated/

# ── Vite / Webpack Cache ─────────────────────────────────────────
.vite/
vite.config.js.timestamp-*
.cache/

# ── Environment & Secrets ────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
electron-builder.env
*.pem
*.key
*.cert
*.p12

# ── Emulator Config Backups (مهم جداً!) ────────────────────────
*.nexus-backup
/emulator-paths.json
/user-config.json

# ── Save States (ملفات ضخمة محلية) ──────────────────────────────
*.p2s
*.gci
*.sav
*.savestate
*.mcr
/tmp-savestates/

# ── Logs ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
electron-log/

# ── OS Files ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE & Editors ───────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.sw?
*.swp

# ── Testing ─────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ────────────────────────────────────────────────────────
*.tgz
*.tar.gz
assets/icons/icon-source.png
.eslintcache