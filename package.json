{
  "name": "nexus-netplay-hub",
  "version": "1.0.0",
  "description": "نظام المحاكاة الشبكي العابر للمنصات",
  "homepage": "https://github.com/guest1200assaf-cell/Nexus-Netplay",
  "main": "src/main/main.js",
  "author": {
    "name": "Nexus Team",
    "email": "nexus@example.com"
  },
  "scripts": {
    "dev":            "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite":           "vite",
    "electron":       "electron .",
    "build":          "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-builder --config electron-builder.yml",
    "build:win":      "npm run build:renderer && electron-builder --win --config electron-builder.yml",
    "build:linux":    "npm run build:renderer && electron-builder --linux --config electron-builder.yml",
    "build:mac":      "npm run build:renderer && electron-builder --mac --config electron-builder.yml",
    "release":        "npm run build:renderer && electron-builder --publish always --config electron-builder.yml",
    "obfuscate":      "node scripts/obfuscate.js",
    "postinstall":    "electron-builder install-app-deps"
  },
  "dependencies": {
    "simple-peer":       "^9.11.1",
    "zustand":           "^4.5.2",
    "nat-upnp":          "^1.1.1",
    "ws":                "^8.17.0",
    "react":             "^18.3.1",
    "react-dom":         "^18.3.1",
    "react-router-dom":  "^6.23.1",
    "electron-updater":  "^6.3.4",
    "electron-log":      "^5.1.6"
  },
  "devDependencies": {
    "electron":              "^31.0.0",
    "electron-builder":      "^24.13.3",
    "vite":                  "^5.2.12",
    "@vitejs/plugin-react":  "^4.3.0",
    "tailwindcss":           "^3.4.4",
    "autoprefixer":          "^10.4.19",
    "postcss":               "^8.4.38",
    "concurrently":          "^8.2.2",
    "wait-on":               "^7.2.0",
    "javascript-obfuscator": "^4.1.1"
  }
}
